+    @staticmethod
+    def _sanitize_system_text(text: str) -> Optional[str]:
+        """Remove volatile Anthropic billing headers from system text."""
+        if not text:
+            return None
+        lines = text.splitlines()
+        if lines and lines[0].startswith("x-anthropic-billing-header:"):
+            sanitized = "\n".join(lines[1:]).lstrip("\n")
+            return sanitized or None
+        return text
+
+    @staticmethod
+    def _extract_system_reminder_text(text: str) -> Optional[str]:
+        """Lift Claude harness system reminders out of user content."""
+        if not text:
+            return None
+        stripped = text.strip()
+        prefix = "<system-reminder>"
+        if not stripped.startswith(prefix):
+            return None
+        remainder = stripped[len(prefix) :].lstrip("\n").strip()
+        return remainder or None
+
+    @staticmethod
+    def _normalize_cache_identifier(value: str) -> str:
+        value = value.strip()
+        if len(value) <= 128:
+            return value
+        return hashlib.sha256(value.encode("utf-8")).hexdigest()
+
+    @staticmethod
+    def _normalize_call_identifier(index: int) -> str:
+        return f"call_{index:04d}"
+
+    @classmethod
+    def _build_call_id_map(
+        cls,
+        messages: List[
+            Union[
+                AnthropicMessagesUserMessageParam,
+                AnthopicMessagesAssistantMessageParam,
+            ]
+        ],
+    ) -> Dict[str, str]:
+        call_id_map: Dict[str, str] = {}
+
+        for message in messages:
+            content = message.get("content")
+            if not isinstance(content, list):
+                continue
+
+            for block in content:
+                if not isinstance(block, dict):
+                    continue
+
+                raw_id: Optional[str] = None
+                block_type = block.get("type")
+                if block_type == "tool_use":
+                    raw_id = block.get("id")
+                elif block_type == "tool_result":
+                    raw_id = block.get("tool_use_id")
+
+                if isinstance(raw_id, str) and raw_id and raw_id not in call_id_map:
+                    call_id_map[raw_id] = cls._normalize_call_identifier(
+                        len(call_id_map) + 1
+                    )
+
+        return call_id_map
+
+    @classmethod
+    def _get_normalized_call_id(
+        cls, raw_id: Any, call_id_map: Dict[str, str]
+    ) -> str:
+        if isinstance(raw_id, str) and raw_id:
+            return call_id_map.get(raw_id, raw_id)
+        return ""
+
+    @classmethod
+    def _get_model_reasoning_effort(cls, model: str) -> Optional[str]:
+        normalized_model = model.strip().lower()
+        for prefix, effort in cls._MODEL_REASONING_EFFORTS.items():
+            if normalized_model.startswith(prefix):
+                return effort
+        return None
+
+    @classmethod
+    def _canonicalize_for_fingerprint(cls, value: Any) -> Any:
+        if isinstance(value, dict):
+            return {
+                key: cls._canonicalize_for_fingerprint(value[key])
+                for key in sorted(value)
+            }
+        if isinstance(value, list):
+            return [cls._canonicalize_for_fingerprint(item) for item in value]
+        return value
+
+    @classmethod
+    def _fingerprint_tool_payload(
+        cls, tools: Optional[List[AllAnthropicToolsValues]]
+    ) -> Optional[str]:
+        if not tools:
+            return None
+        canonical_tools = cls._canonicalize_for_fingerprint(tools)
+        serialized = json.dumps(
+            canonical_tools,
+            ensure_ascii=False,
+            separators=(",", ":"),
+        )
+        return hashlib.sha256(serialized.encode("utf-8")).hexdigest()
+
+    @classmethod
+    def _get_stable_cache_identifier(
+        cls, metadata: Optional[Dict[str, Any]]
+    ) -> Optional[str]:
+        if not isinstance(metadata, dict):
+            return None
+
+        user_id = metadata.get("user_id")
+        if user_id is None:
+            return None
+
+        parsed_user_id: Optional[Dict[str, Any]] = None
+        raw_user_id: Optional[str] = None
+
+        if isinstance(user_id, str):
+            raw_user_id = user_id
+            try:
+                parsed = json.loads(user_id)
+            except (TypeError, ValueError):
+                parsed = None
+            if isinstance(parsed, dict):
+                parsed_user_id = parsed
+        elif isinstance(user_id, dict):
+            parsed_user_id = user_id
+            raw_user_id = json.dumps(user_id, sort_keys=True, ensure_ascii=False)
+
+        if parsed_user_id is not None:
+            for key in ("device_id", "account_uuid", "user_id"):
+                value = parsed_user_id.get(key)
+                if isinstance(value, str) and value.strip():
+                    return cls._normalize_cache_identifier(value)
+
+            stable_bits = {
+                key: value
+                for key, value in parsed_user_id.items()
+                if key != "session_id" and value not in (None, "")
+            }
+            if stable_bits:
+                return cls._normalize_cache_identifier(
+                    json.dumps(stable_bits, sort_keys=True, separators=(",", ":"))
+                )
+
+        if isinstance(raw_user_id, str) and raw_user_id.strip():
+            return cls._normalize_cache_identifier(raw_user_id)
+
         return None
 
+    @classmethod
+    def _lift_embedded_system_reminders(
+        cls,
+        messages: List[
+            Union[
+                AnthropicMessagesUserMessageParam,
+                AnthopicMessagesAssistantMessageParam,
+            ]
+        ],
+    ) -> Tuple[
+        List[
+            Union[
+                AnthropicMessagesUserMessageParam,
+                AnthopicMessagesAssistantMessageParam,
+            ]
+        ],
+        List[str],
+    ]:
+        extracted_reminders: List[str] = []
+        normalized_messages: List[
+            Union[
+                AnthropicMessagesUserMessageParam,
+                AnthopicMessagesAssistantMessageParam,
+            ]
+        ] = []
+
+        for message in messages:
+            content = message.get("content")
+            if message.get("role") != "user" or not isinstance(content, list):
+                normalized_messages.append(cast(Any, dict(message)))
+                continue
+
+            rewritten_blocks: List[Any] = []
+            for block in content:
+                if not isinstance(block, dict) or block.get("type") != "text":
+                    rewritten_blocks.append(block)
+                    continue
+
+                reminder_text = cls._extract_system_reminder_text(block.get("text", ""))
+                if reminder_text is not None:
+                    extracted_reminders.append(reminder_text)
+                    continue
+
+                rewritten_blocks.append(block)
+
+            rewritten_message = dict(message)
+            rewritten_message["content"] = rewritten_blocks
+            normalized_messages.append(cast(Any, rewritten_message))
+
+        return normalized_messages, extracted_reminders
+
